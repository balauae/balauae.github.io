---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>👋 Hey, I'm Bala</h1>
			<p>
				AI Engineer based in <strong>Abu Dhabi, UAE</strong>. I build and tinker with local AI systems —
				LLMs, GPU inference, Stable Diffusion, and whatever else runs fast on a RTX 5090.
			</p>
			<p>
				This blog is where I write about things I'm learning and building:
			</p>
			<ul>
				<li>🤖 Local AI & LLM inference (Ollama, ComfyUI, vLLM)</li>
				<li>🦞 OpenClaw — AI gateway and automation</li>
				<li>🐳 Docker, GPU computing, high-performance setups</li>
				<li>🛠️ Tools, workflows, and dev notes</li>
			</ul>
			<p>
				<a href="/blog">Read the blog →</a> &nbsp;|&nbsp; <a href="/about">About me →</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
